---
interface Item { image: string; caption: string; link?: string; }
interface Props { items: Item[]; }
const { items } = Astro.props;
---
<div class="orbit" data-orbit>
  {items.map((it) => (
    <a class="orbit-card" href={it.link ?? '#'} aria-label={it.caption}>
      <img src={it.image} alt={it.caption} width="138" height="174" loading="lazy" />
      <span class="orbit-cap">{it.caption}</span>
    </a>
  ))}
</div>

<style>
  /* Hidden by default. The script only reveals it as a ring on screens wide
     enough to show the collage properly; on small/narrow screens and mobile
     there are no photos — just the centered name + nav. */
  .orbit { display: none; }
  .orbit-card { position: relative; width: 138px; height: 174px; border-radius: 10px; overflow: hidden;
    border: 1px solid rgba(255,255,255,.10); box-shadow: 0 14px 40px rgba(0,0,0,.45); }
  .orbit-card img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .orbit-cap { position: absolute; left: 0; right: 0; bottom: 0; padding: 7px 9px; font-size: 11px;
    color: #fff; background: linear-gradient(transparent, rgba(0,0,0,.72)); opacity: 0; transition: opacity .3s; }
  .orbit-card:hover .orbit-cap, .orbit-card:focus-visible .orbit-cap { opacity: 1; }

  .orbit.is-ring { display: block; position: absolute; inset: 0; }
  .orbit.is-ring .orbit-card { position: absolute; left: 50%; top: 50%; margin: -87px 0 0 -69px; will-change: transform, opacity; }
</style>

<script>
  // Show the ring only when there's room for it AND motion is allowed.
  const mqWide = matchMedia('(min-width: 900px)');
  const mqReduce = matchMedia('(prefers-reduced-motion: reduce)');
  const root = document.querySelector('[data-orbit]') as HTMLElement | null;
  if (root) {
    const cards = Array.from(root.querySelectorAll('.orbit-card')) as HTMLElement[];
    const N = cards.length;
    let theta = 0, hover = -1, raf = 0, active = false;

    cards.forEach((c, i) => {
      c.addEventListener('mouseenter', () => (hover = i));
      c.addEventListener('mouseleave', () => (hover = -1));
      c.addEventListener('focus', () => (hover = i));
      c.addEventListener('blur', () => (hover = -1));
    });

    function frame() {
      const host = root!.parentElement as HTMLElement;
      const W = host.clientWidth, H = host.clientHeight, R = Math.min(W, H) * 0.56;
      if (hover < 0) theta += 0.00075 * 0.5; // slow
      for (let i = 0; i < N; i++) {
        const a = theta + i * (2 * Math.PI / N);
        const x = Math.cos(a) * R, y = Math.sin(a) * R * 0.62;
        const depth = (Math.sin(a) + 1) / 2;
        const sc = (0.78 + depth * 0.4) * (hover === i ? 1.26 : 1);
        cards[i].style.transform = `translate(${x}px,${y}px) scale(${sc})`;
        cards[i].style.zIndex = String(hover === i ? 12 : Math.round(1 + depth * 11));
        // depth comes from scale, not opacity — keeps photos solid (no gray wash in light mode)
        cards[i].style.opacity = String(hover >= 0 && hover !== i ? 0.62 : 1);
      }
      raf = requestAnimationFrame(frame);
    }

    function enable() {
      if (active) return; active = true; root!.classList.add('is-ring'); frame();
    }
    function disable() {
      if (!active) return; active = false; cancelAnimationFrame(raf);
      root!.classList.remove('is-ring');
      cards.forEach((c) => { c.style.transform = ''; c.style.zIndex = ''; c.style.opacity = ''; });
    }
    function evaluate() { (mqWide.matches && !mqReduce.matches) ? enable() : disable(); }

    evaluate();
    mqWide.addEventListener('change', evaluate);
    mqReduce.addEventListener('change', evaluate);
  }
</script>
