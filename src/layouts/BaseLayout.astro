---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import PaintSplotches from '../components/PaintSplotches.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  cover?: boolean;
}

const {
  title,
  description = 'Simon Kuester — cybersecurity professional. Experience, projects, and writing.',
  image = '/favicon.svg',
  type = 'website',
  cover = false,
} = Astro.props;

const fullTitle = title === 'Simon Kuester' ? title : `${title} — Simon Kuester`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
---
<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Simon Kuester — Writing" href="/rss.xml" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <ClientRouter />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Set theme before paint, re-apply after each view transition (no flash), and
         handle the toggle via one delegated listener so it keeps working across swaps -->
    <script is:inline>
      (() => {
        const apply = () => {
          const saved = localStorage.getItem('theme');
          document.documentElement.setAttribute('data-theme', saved === 'light' ? 'light' : 'dark');
        };
        apply();
        if (!window.__themeBound) {
          window.__themeBound = true;
          document.addEventListener('astro:after-swap', apply);
          document.addEventListener('click', (e) => {
            const t = e.target instanceof Element ? e.target.closest('#theme-toggle') : null;
            if (!t) return;
            const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
          });
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="visually-hidden">Skip to content</a>
    {!cover && <PaintSplotches />}
    {cover ? <div class="cover-toggle"><ThemeToggle /></div> : <Header />}
    <main id="main">
      <slot />
    </main>
    {!cover && <Footer />}
  </body>
</html>

<style>
  .cover-toggle { position: fixed; top: 16px; right: 16px; z-index: 20; }
</style>
